generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  products    Product[]
  suppliers   Supplier[]
  customers   Customer[]
  purchaseOrders PurchaseOrder[]
  salesOrders SalesOrder[]
  qboConnection QboConnection?
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(WAREHOUSE)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  SALES
  WAREHOUSE
}

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  description   String?
  unit          String   @default("EA")
  sellPriceNzd  Decimal  @db.Decimal(10,2)
  reorderPoint  Int      @default(0)
  imageUrl      String?
  notes         String?
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])

  stockLevel    StockLevel?
  transactions  InventoryTransaction[]
  poLines       PurchaseOrderLine[]
  soLines       SalesOrderLine[]

  @@index([tenantId])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  currency    String   @default("NZD")
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrders SalesOrder[]

  @@index([tenantId])
}

model StockLevel {
  productId   String   @id
  qty         Int      @default(0)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model InventoryTransaction {
  id          String   @id @default(cuid())
  productId   String
  qtyChange   Int
  type        TransactionType
  referenceId String?
  notes       String?
  userId      String?
  createdAt   DateTime @default(now())
  tenantId    String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([productId, createdAt])
}

enum TransactionType {
  PO_RECEIPT
  SO_PICK
  ADJUSTMENT
  RETURN
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  poNumber      String              @unique
  supplierId    String
  status        POStatus            @default(DRAFT)
  orderDate     DateTime            @default(now())
  expectedDate  DateTime?
  totalCostNzd  Decimal?            @db.Decimal(12,2)
  freightNzd    Decimal?            @db.Decimal(10,2)
  notes         String?
  tenantId      String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  lines         PurchaseOrderLine[]
  qboBillId     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([tenantId, status])
}

enum POStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

model PurchaseOrderLine {
  id          String        @id @default(cuid())
  poId        String
  productId   String
  qtyOrdered  Int
  unitCostNzd Decimal       @db.Decimal(10,2)
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [productId], references: [id])
}

model SalesOrder {
  id            String           @id @default(cuid())
  soNumber      String           @unique
  customerId    String
  status        SOStatus         @default(DRAFT)
  orderDate     DateTime         @default(now())
  shippedDate   DateTime?
  trackingRef   String?
  notes         String?
  tenantId      String
  customer      Customer         @relation(fields: [customerId], references: [id])
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  lines         SalesOrderLine[]
  qboInvoiceId  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tenantId, status])
}

enum SOStatus {
  DRAFT
  CONFIRMED
  PICKED
  SHIPPED
  CANCELLED
}

model SalesOrderLine {
  id          String    @id @default(cuid())
  soId        String
  productId   String
  qtyOrdered  Int
  salesOrder  SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  product     Product    @relation(fields: [productId], references: [id])
}

model QboConnection {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  realmId         String
  accessToken     String
  refreshTokenEnc String
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model QboSyncJob {
  id          String   @id @default(cuid())
  tenantId    String
  entityType  String   // "INVOICE" | "BILL"
  entityId    String
  status      String   @default("PENDING") // PENDING | SUCCESS | FAILED
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}
