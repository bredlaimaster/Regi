generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core tenant / auth ───────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  products         Product[]
  suppliers        Supplier[]
  customers        Customer[]
  purchaseOrders   PurchaseOrder[]
  salesOrders      SalesOrder[]
  qboConnection    QboConnection?
  brands           Brand[]
  channels         Channel[]
  territories      Territory[]
  budgets          Budget[]
  batches          Batch[]
  reportSnapshots  ReportSnapshot[]
  scheduledReports ScheduledReport[]
  reportDeliveries ReportDelivery[]
  proformaInvoices ProformaInvoice[]
  stockReservations StockReservation[]
  creditNotes      CreditNote[]
  priceGroups      PriceGroup[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         Role     @default(WAREHOUSE)
  passwordHash String?
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  // Rep relations
  customers       Customer[]    @relation("CustomerRep")
  budgets         Budget[]
  reservations    StockReservation[] @relation("ReservationRep")

  @@index([tenantId])
}

enum Role {
  ADMIN
  SALES
  WAREHOUSE
}

// ─── Phase A: Dimension tables ────────────────────────────────────────────────

/// Brand (e.g. Silkymit, Inspired Beauty, Hask, Nizoral, Sebapharma)
model Brand {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]
  budgets   Budget[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Sales channel (Pharmacy, Salon, Spa, Online, Export, Other)
model Channel {
  id        String     @id @default(cuid())
  name      String
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]
  budgets   Budget[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Sales territory (e.g. Auckland, Wellington, South Island, Export)
model Territory {
  id        String     @id @default(cuid())
  name      String
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]
  budgets   Budget[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  description   String?
  unit          String   @default("EA")
  sellPriceNzd  Decimal  @db.Decimal(10,2)
  reorderPoint  Int      @default(0)
  imageUrl      String?
  notes         String?
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])

  // Phase A additions
  brandId       String?
  brand         Brand?   @relation(fields: [brandId], references: [id])
  costNzd       Decimal? @db.Decimal(12,4)  // rolling landed-cost average (NZD per unit)
  caseQty       Int      @default(1)         // units per carton / case
  isTester      Boolean  @default(false)
  active        Boolean  @default(true)

  // Client data fields
  supplierCode  String?                      // Supplier's own part number (e.g. 14099-10, 34316H)
  binLocation   String?                      // Warehouse bin location (e.g. F08B01, G07A01)
  unitBarcode   String?                      // Unit-level EAN/UPC barcode
  caseBarcode   String?                      // Case-level barcode

  stockLevel    StockLevel?
  transactions  InventoryTransaction[]
  poLines       PurchaseOrderLine[]
  soLines       SalesOrderLine[]
  batches       Batch[]
  reservations  StockReservation[]
  prices        ProductPrice[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@index([brandId])
  // Mobile app scans barcodes — indexed to keep scan-to-product lookups O(log n).
  @@index([tenantId, unitBarcode])
  @@index([tenantId, caseBarcode])
}

/// User-managed pricing group (e.g. Retail, Wholesale, Gold Tier, Distributor).
/// Replaces the legacy PriceTier enum. Customers belong to exactly one group;
/// each product can carry one price per group with optional quantity breaks.
model PriceGroup {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prices     ProductPrice[]
  customers  Customer[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Per-product pricing by pricing group, with optional quantity breaks.
/// Price resolution: find row matching (productId, priceGroupId) with largest
/// minQty <= order qty. If no match, fall back to product.sellPriceNzd.
model ProductPrice {
  id            String     @id @default(cuid())
  productId     String
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceGroupId  String
  priceGroup    PriceGroup @relation(fields: [priceGroupId], references: [id], onDelete: Cascade)
  unitPrice     Decimal    @db.Decimal(10,2)
  minQty        Int        @default(1)   // quantity-break threshold

  @@unique([productId, priceGroupId, minQty])
  @@index([productId, priceGroupId])
  @@index([priceGroupId])
}

// ─── Supplier ─────────────────────────────────────────────────────────────────

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  currency      String   @default("NZD")
  acctCode      String?                    // Accounting shortcode (e.g. MURRELL, BURTS)
  paymentTerms  String?                    // e.g. "20th month", "60 days invoice"
  taxRule       String   @default("GST15") // GST15 | ZERO | IMPORT_GST | EXEMPT
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Phase C — Unleashed-style supplier fields
  gstVatNumber      String?
  bankName          String?
  bankBranch        String?
  bankAccount       String?
  minimumOrderValue Decimal? @db.Decimal(12,2)
  deliveryLeadDays  Int?
  notes             String?
  /// Postal address JSON: { name?, line1, line2?, suburb?, city?, state?, postcode?, country? }
  postalAddress     Json?
  /// Physical address JSON: { name?, line1, line2?, suburb?, city?, state?, postcode?, country? }
  physicalAddress   Json?

  products       Product[]
  purchaseOrders PurchaseOrder[]
  batches        Batch[]
  contacts       SupplierContact[]

  @@index([tenantId])
}

/// Multiple contacts per supplier (primary, purchasing, accounts, etc.)
model SupplierContact {
  id           String   @id @default(cuid())
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  firstName    String?
  lastName     String?
  email        String?
  website      String?
  tollFreeNo   String?
  phone        String?
  fax          String?
  mobilePhone  String?
  officePhone  String?
  ddi          String?
  comments     String?
  isPurchasing Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([supplierId])
}

// ─── Customer ─────────────────────────────────────────────────────────────────

/// Address JSON shape: { line1, line2?, city, postcode?, country }
model Customer {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  /// Legacy single-address field (kept for migration compatibility; prefer billTo)
  address     String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Phase A additions
  channelId   String?
  channel     Channel?   @relation(fields: [channelId], references: [id])
  territoryId String?
  territory   Territory? @relation(fields: [territoryId], references: [id])
  salesRepId  String?
  salesRep    User?      @relation("CustomerRep", fields: [salesRepId], references: [id])
  /// Bill-to address: { line1, line2?, city, postcode?, country }
  billTo      Json?
  /// Ship-to addresses array: [{ label?, line1, line2?, city, postcode?, country }]
  shipTos     Json?

  // Phase B — financial / pricing
  creditLimit   Decimal?    @db.Decimal(12,2)
  paymentTerms  String?
  priceGroupId  String?
  priceGroup    PriceGroup? @relation(fields: [priceGroupId], references: [id])

  // Phase D — Unleashed-style customer fields
  acctCode        String?
  currency        String     @default("NZD")
  taxNumber       String?
  taxRule         String     @default("GST15") // matches supplier taxRule
  notes           String?
  /// Postal address: { name?, line1, line2?, suburb?, city?, state?, postcode?, country? }
  postalAddress   Json?
  /// Physical address (same shape)
  physicalAddress Json?

  salesOrders  SalesOrder[]
  reservations StockReservation[]
  creditNotes  CreditNote[]
  contacts     CustomerContact[]

  @@index([tenantId])
  @@index([tenantId, channelId])
  @@index([tenantId, territoryId])
  @@index([tenantId, salesRepId])
  @@index([tenantId, acctCode])
  @@index([tenantId, priceGroupId])
}

// ─── CustomerContact ──────────────────────────────────────────────────────────

model CustomerContact {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  firstName    String?
  lastName     String?
  email        String?
  website      String?
  tollFreeNo   String?
  phone        String?
  fax          String?
  mobilePhone  String?
  officePhone  String?
  ddi          String?
  comments     String?
  /// Flag the primary billing/purchasing contact — used as default on invoices/POs.
  isPurchasing Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
}

// ─── Stock ────────────────────────────────────────────────────────────────────

model StockLevel {
  productId   String   @id
  qty         Int      @default(0)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model InventoryTransaction {
  id          String   @id @default(cuid())
  productId   String
  qtyChange   Int
  type        TransactionType
  referenceId String?
  notes       String?
  userId      String?
  createdAt   DateTime @default(now())
  tenantId    String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([productId, createdAt])
  @@index([tenantId, productId, type])
}

enum TransactionType {
  PO_RECEIPT
  SO_PICK
  ADJUSTMENT
  RETURN
}

// ─── Phase E: Batch / lot tracking ───────────────────────────────────────────

/// Batch/lot record created when a PO is received. Drives expiry & tester reports.
model Batch {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  batchCode   String?
  expiryDate  DateTime? @db.Date
  qtyReceived Int
  qtyOnHand   Int       @default(0)
  costNzd     Decimal?  @db.Decimal(12,4)  // landed unit cost NZD at receipt
  receivedAt  DateTime  @default(now())
  poId        String?                        // source PO for traceability
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId, productId])
  @@index([tenantId, expiryDate])
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

model PurchaseOrder {
  id            String              @id @default(cuid())
  poNumber      String              @unique
  supplierId    String
  status        POStatus            @default(DRAFT)
  orderDate     DateTime            @default(now())
  expectedDate  DateTime?
  currency      String              @default("NZD")
  fxRate        Decimal             @default(1) @db.Decimal(14,8)
  fxRateDate    DateTime?
  totalCost     Decimal?            @db.Decimal(12,2)
  freight       Decimal?            @db.Decimal(10,2)
  totalCostNzd  Decimal?            @db.Decimal(12,2)
  freightNzd    Decimal?            @db.Decimal(10,2)
  notes         String?
  tenantId      String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  lines         PurchaseOrderLine[]
  receiveCharges PoReceiveCharge[]
  qboBillId     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, supplierId])
}

enum POStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

model PurchaseOrderLine {
  id            String        @id @default(cuid())
  poId          String
  productId     String
  qtyOrdered    Int
  qtyReceived   Int           @default(0)
  unitCost      Decimal       @db.Decimal(12,4)
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([poId, productId])
}

// ─── Sales Orders ─────────────────────────────────────────────────────────────

model SalesOrder {
  id               String           @id @default(cuid())
  soNumber         String           @unique
  customerId       String
  status           SOStatus         @default(DRAFT)
  orderDate        DateTime         @default(now())
  shippedDate      DateTime?
  trackingRef      String?
  notes            String?
  tenantId         String
  customer         Customer         @relation(fields: [customerId], references: [id])
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  lines            SalesOrderLine[]
  qboInvoiceId     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Phase I additions
  selectedShipTo   Json?            // { label?, line1, city, postcode?, country }
  discountPct      Decimal?         @db.Decimal(5,2)  // order-level discount %
  isProforma       Boolean          @default(false)
  proformaIssuedAt DateTime?
  creditNotes      CreditNote[]
  reservations     StockReservation[]
  proforma         ProformaInvoice?

  @@index([tenantId, status])
  @@index([tenantId, orderDate])
  @@index([tenantId, shippedDate])
  @@index([tenantId, customerId])
}

enum SOStatus {
  DRAFT
  CONFIRMED
  PICKED
  SHIPPED
  CANCELLED
}

model SalesOrderLine {
  id          String     @id @default(cuid())
  soId        String
  productId   String
  qtyOrdered  Int
  qtyPicked   Int        @default(0)   // Phase I: partial picks
  unitPrice   Decimal    @default(0)   @db.Decimal(10,2)
  discountPct Decimal    @default(0)   @db.Decimal(5,2)   // Phase I: per-line discount %
  salesOrder  SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  product     Product    @relation(fields: [productId], references: [id])

  @@index([soId, productId])
}

// ─── Phase I: Proforma invoice ─────────────────────────────────────────────────

/// A proforma is generated from a DRAFT/CONFIRMED SO. When the SO ships it
/// becomes a tax invoice. Proformas can be emailed to customers for pre-payment.
model ProformaInvoice {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  soId       String   @unique
  salesOrder SalesOrder? @relation(fields: [soId], references: [id], onDelete: Cascade)
  pfNumber   String   @unique
  issuedAt   DateTime @default(now())
  expiresAt  DateTime?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

// ─── Phase I: Stock reservation ───────────────────────────────────────────────

/// Reserve units for a customer / sales rep before an SO is created.
model StockReservation {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  repId       String?
  rep         User?     @relation("ReservationRep", fields: [repId], references: [id])
  soId        String?
  salesOrder  SalesOrder? @relation(fields: [soId], references: [id])
  qtyReserved Int
  expiresAt   DateTime?
  notes       String?
  released    Boolean   @default(false)
  releasedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId, productId])
  @@index([tenantId, customerId])
}

// ─── Phase I: Credit notes ────────────────────────────────────────────────────

/// Auto-generated 2.5% credit on qualifying shipments (or manual recharges).
model CreditNote {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cnNumber     String    @unique
  soId         String?
  salesOrder   SalesOrder? @relation(fields: [soId], references: [id])
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  amountNzd    Decimal   @db.Decimal(12,2)
  reason       CreditNoteReason
  notes        String?
  qboCreditId  String?
  issuedAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([tenantId, customerId])
  @@index([tenantId, issuedAt])
}

enum CreditNoteReason {
  AUTO_REBATE       // 2.5% on qualifying shipment
  RECHARGE          // customer recharge / partial replacement
  RETURN            // goods return
  PRICE_CORRECTION  // price error correction
  OTHER
}

// ─── Phase B: Budgets ─────────────────────────────────────────────────────────

/// Monthly budget entries. period = 1–12, fiscalYear is the April-start year
/// e.g. fiscal year 2025 = April 2025 – March 2026.
model Budget {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalYear  Int                     // e.g. 2025
  period      Int                     // 1–12 (1 = April)
  lineType    BudgetLineType
  amountNzd   Decimal   @db.Decimal(14,2)
  brandId     String?
  brand       Brand?    @relation(fields: [brandId], references: [id])
  channelId   String?
  channel     Channel?  @relation(fields: [channelId], references: [id])
  territoryId String?
  territory   Territory? @relation(fields: [territoryId], references: [id])
  repId       String?
  rep         User?     @relation(fields: [repId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, fiscalYear, period, lineType, brandId, channelId, territoryId, repId])
  @@index([tenantId, fiscalYear, period])
}

enum BudgetLineType {
  SALES
  COGS
  GROSS_MARGIN
  FREIGHT_IN
  FREIGHT_OUT
  MARKETING
  REBATE
}

// ─── Phase C: Report infrastructure ──────────────────────────────────────────

/// Frozen monthly snapshot of a report's computed data (for historical accuracy)
model ReportSnapshot {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportKey  String                      // e.g. "monthly-sales-analysis"
  period     String                      // e.g. "2025-04" (YYYY-MM)
  data       Json                        // serialized report payload
  createdAt  DateTime @default(now())

  @@unique([tenantId, reportKey, period])
  @@index([tenantId, reportKey])
}

/// Scheduled report definition (which report, when to run, who receives it)
model ScheduledReport {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportKey   String
  cronExpr    String   @default("0 8 1 * *")  // default: 8am on 1st of month
  recipients  Json                              // string[] of email addresses
  enabled     Boolean  @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

/// Delivery log for each report email sent
model ReportDelivery {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportKey      String
  period         String
  recipientEmail String
  status         String   @default("SENT")   // SENT | FAILED
  resendId       String?
  error          String?
  deliveredAt    DateTime @default(now())

  @@index([tenantId, reportKey])
}

// ─── QBO ─────────────────────────────────────────────────────────────────────

model QboConnection {
  id                     String    @id @default(cuid())
  tenantId               String    @unique
  realmId                String
  accessToken            String
  refreshTokenEnc        String
  expiresAt              DateTime              // Access token expiry (~1 hr)
  refreshTokenExpiresAt  DateTime?             // Refresh token expiry (~100 days)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─── PO Receiving charges ─────────────────────────────────────────────────────

/// Additional charges (freight, customs, handling, etc.) captured at PO receive time
model PoReceiveCharge {
  id         String        @id @default(cuid())
  poId       String
  po         PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  label      String                        // e.g. "Freight", "Customs duty", "Handling"
  amount     Decimal       @db.Decimal(12,2) // In charge currency
  currency   String        @default("NZD")  // Currency of the charge (may differ from PO)
  fxRate     Decimal       @default(1) @db.Decimal(14,8) // FX rate to NZD at receive time
  amountNzd  Decimal       @db.Decimal(12,2) // Converted to NZD
  taxRate    Decimal       @default(0) @db.Decimal(5,2) // Tax rate (e.g. 15.00 for GST, 0 for zero-rated)
  taxAmountNzd Decimal     @default(0) @db.Decimal(12,2) // Tax amount in NZD
  invoiceRef String?                        // Supplier invoice number
  createdAt  DateTime      @default(now())

  @@index([poId])
}

model QboSyncJob {
  id          String   @id @default(cuid())
  tenantId    String
  entityType  String
  entityId    String
  status      String   @default("PENDING")
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

// ─── FX rates ─────────────────────────────────────────────────────────────────

/// Daily FX rates sourced from Frankfurter.app (ECB reference rates).
/// nzdPerUnit = number of NZD per 1 unit of the given foreign currency.
model ExchangeRate {
  date        DateTime @db.Date
  currency    String
  nzdPerUnit  Decimal  @db.Decimal(14,8)
  source      String   @default("frankfurter")
  createdAt   DateTime @default(now())

  @@id([date, currency])
  @@index([currency, date])
}
